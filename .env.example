# Notion
# Use data source IDs (not page URLs) for each database.
NOTION_API_TOKEN=
NOTION_IDEAS_DATABASE_ID=
NOTION_PROJECTS_DATABASE_ID=
NOTION_TASKS_DATABASE_ID=

# OpenAI
OPENAI_API_KEY=
# Demo-pinned model for stable output/cost.
OPENAI_MODEL=gpt-4o-mini
# Increase if structured generations become slower during demo or production.
OPENAI_TIMEOUT_MS=60000

# GitHub
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# API
API_HOST=0.0.0.0
API_PORT=3000
# Optional: protect POST /worker/run when API is exposed publicly.
API_BEARER_TOKEN=
